```gitignore
# =========================
# 🐍 PYTHON
# =========================
__pycache__/
*.py[cod]
*$py.class

# Ambiente virtual
.venv/
venv/
env/
ENV/

# Variáveis de ambiente
.env

# Logs
*.log

# Build / distribuição
build/
dist/
*.egg-info/

# Cache / testes
.pytest_cache/
.coverage
htmlcov/

# =========================
# 🗄️ DATABASE
# =========================
*.db
*.sqlite3

# =========================
# 🌐 JAVASCRIPT / NODE
# =========================
node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build
dist/
build/

# Env frontend
.env.local
.env.development.local
.env.test.local
.env.production.local

# =========================
# 💻 VSCODE
# =========================
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Histórico local
.history/

# =========================
# 🧹 GERAL
# =========================
.DS_Store
Thumbs.db
```
